{
  "name": "P4 IDS Dev Container",

  // Build directly from Dockerfile — simpler than docker-compose
  "build": {
    "dockerfile": "../Dockerfile",
    "context": ".."
  },

  // Required for ip link / veth creation inside the container
  "runArgs": ["--privileged"],

  "workspaceFolder": "/workspace",

  "mounts": [
    "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached"
  ],

  // Run entrypoint after container starts to set up veth pair + compile P4
  "postStartCommand": "bash /usr/local/bin/docker-entrypoint.sh || true",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-azuretools.vscode-docker",
        "secanis.p4-lang"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/bin/python3",
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}